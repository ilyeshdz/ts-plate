{
  "name": "@ilyeshdz/ts-plate",
  "version": "0.5.0",
  "description": "A tiny TypeScript library for composing file trees and generator output.",
  "homepage": "https://github.com/ilyeshdz/ts-plate#readme",
  "bugs": {
    "url": "https://github.com/ilyeshdz/ts-plate/issues"
  },
  "license": "MIT",
  "author": "Ilyes Hernandez <hdz.ilyes@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ilyeshdz/ts-plate.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "changelogen --release --no-github --push",
    "prepublishOnly": "pnpm run build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "changelogen": "^0.6.1",
    "husky": "^9.1.7",
    "memfs": "^4.57.7",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitepress": "2.0.0-alpha.17",
    "vitest": "^4.1.5"
  }
}
