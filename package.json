{
  "name": "ts-plate",
  "type": "module",
  "version": "0.1.0",
  "description": "A starter for creating a TypeScript package.",
  "author": "Ilyes Hernandez <hdz.ilyes@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/ilyeshdz/ts-plate#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ilyeshdz/ts-plate.git"
  },
  "bugs": {
    "url": "https://github.com/ilyeshdz/ts-plate/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.2",
    "@typescript/native-preview": "7.0.0-dev.20260509.2",
    "bumpp": "^11.1.0",
    "tsdown": "^0.22.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
